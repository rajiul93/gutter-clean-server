DATABASE_URL=mongodb://localhost:27017/myapp
PORT=3001

# Comma-separated browser origins (no trailing slashes). Include every deploy URL your browser uses.
CORS_ORIGIN=http://localhost:3000,https://gutter-clean-front.vercel.app

# Firebase — used only to verify ID tokens (JWKS). Same value as the web app's project ID.
# Prefer FIREBASE_PROJECT_ID on the server; if unset, NEXT_PUBLIC_FIREBASE_PROJECT_ID is used.
FIREBASE_PROJECT_ID=your-firebase-project-id

# Comma-separated emails that receive ADMIN role on first login
ADMIN_EMAILS=owner@example.com
