DATABASE_URL=mongodb://localhost:27017/myapp
PORT=3001

# Comma-separated browser origins (your Next.js site)
CORS_ORIGIN=http://localhost:3000

# Firebase — same project ID as the web app (NEXT_PUBLIC_FIREBASE_PROJECT_ID).
# Used only to verify ID tokens (JWKS). All user/booking/address data is in MongoDB via Mongoose.
FIREBASE_PROJECT_ID=your-firebase-project-id

# Comma-separated emails that receive ADMIN role on first login
ADMIN_EMAILS=owner@example.com
